{
  "name": "secure-send-client",
  "version": "2.0.3",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite",
    "debug": "vite --debug",
    "build": "run-s type-check build-app build-worker",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
    "prettier": "pnpm exec prettier --write .",
    "build-app": "vite build",
    "build-worker": "vite build --mode worker",
    "lint": "eslint . --fix",
    "prettier-verify": "prettier . --check --config ./.prettierrc.json",
    "test": "vitest"
  },
  "dependencies": {
    "vee-validate": "^4.15.1",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.5.0",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "happy-dom": "^20.8.3",
    "jiti": "^2.6.1",
    "npm-run-all": "^4.1.5",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.0",
    "vite-plugin-mkcert": "^1.17.10",
    "vitest": "^4.1.0",
    "vue-tsc": "^3.2.5"
  }
}
